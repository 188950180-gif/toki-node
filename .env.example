# Toki 节点环境变量配置示例

# 数据存储目录
TOKI_DATA_DIR=./data

# 网络配置
TOKI_NETWORK_LISTEN=0.0.0.0:30333
TOKI_BOOTSTRAP_PEERS=

# API 配置
TOKI_API_LISTEN=0.0.0.0:8080
TOKI_API_CORS=true

# 共识配置
TOKI_MINING=true
TOKI_MINING_THREADS=6

# AI 配置
TOKI_AI_ENABLE=true
TOKI_AI_DISTRIBUTION_INTERVAL=1000
TOKI_AI_THETA_INTERVAL=100

# 日志配置
RUST_LOG=info

# 治理配置
TOKI_GOVERNANCE_ENABLE=true
TOKI_KEY_ROTATION_DAYS=90
